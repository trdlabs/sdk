{
  "$id": "https://trading-platform/017/backtest-run-request.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/BacktestRunRequest",
  "definitions": {
    "BacktestRunRequest": {
      "type": "object",
      "properties": {
        "runId": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "research",
            "review",
            "promotion"
          ]
        },
        "moduleRef": {
          "$ref": "#/definitions/Ref",
          "description": "baseline-модуль по ссылке+версии (FR-026)."
        },
        "overlayRefs": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Ref"
          },
          "description": "Явно упорядоченный массив overlays; дубликат ref/version → `duplicate_overlay_ref`."
        },
        "datasetRef": {
          "type": "string"
        },
        "symbols": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeframe": {
          "type": "string"
        },
        "period": {
          "$ref": "#/definitions/RunPeriod"
        },
        "params": {
          "type": "object"
        },
        "riskProfileRef": {
          "$ref": "#/definitions/Ref",
          "description": "Обязателен, если конфиг способен открыть позицию (FR-027)."
        },
        "executionProfileRef": {
          "$ref": "#/definitions/Ref"
        },
        "realityModelRef": {
          "$ref": "#/definitions/Ref",
          "description": "Ф1 `shared-execution-engine` (аддитивно) — версионированная модель среды исполнения (`RealityModel`, reality-model.ts). Отсутствует ⇒ среда читается из встроенных слотов `ExecutionProfile` (dual-read-окно, `resolveRealityModel`)."
        },
        "parameterGrid": {
          "type": "object"
        },
        "seed": {
          "type": "number",
          "description": "Детерминизм (FR-028)."
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Имена из `MetricCatalog` (FR-026); неизвестное → `unknown_metric`."
        },
        "robustnessChecks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "runId",
        "mode",
        "moduleRef",
        "datasetRef",
        "symbols",
        "timeframe",
        "period",
        "seed",
        "metrics"
      ],
      "additionalProperties": false,
      "description": "Самодостаточный запрос для будущего runner'а (FR-024). `overlayRefs` — ЯВНО упорядоченный массив (implicit ordering запрещён); метрики — имена из `MetricCatalog`."
    },
    "Ref": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "version"
      ],
      "additionalProperties": false,
      "description": "Ссылка на модуль/профиль по id+version."
    },
    "RunPeriod": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        }
      },
      "required": [
        "from",
        "to"
      ],
      "additionalProperties": false,
      "description": "Период данных прогона."
    }
  },
  "title": "BacktestRunRequest"
}
