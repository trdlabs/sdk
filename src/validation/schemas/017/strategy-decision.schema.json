{
  "$id": "https://trading-platform/017/strategy-decision.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/StrategyDecision",
  "definitions": {
    "StrategyDecision": {
      "anyOf": [
        {
          "$ref": "#/definitions/EnterDecision"
        },
        {
          "$ref": "#/definitions/ExitDecision"
        },
        {
          "$ref": "#/definitions/AddToPositionDecision"
        },
        {
          "$ref": "#/definitions/UpdateProtectionDecision"
        },
        {
          "$ref": "#/definitions/AnnotateDecision"
        },
        {
          "$ref": "#/definitions/IdleDecision"
        }
      ],
      "description": "Замкнутый union решений стратегии (FR-006)."
    },
    "EnterDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "enter"
        },
        "side": {
          "type": "string",
          "enum": [
            "long",
            "short"
          ]
        },
        "entry": {
          "type": "object"
        },
        "stop": {
          "type": "number"
        },
        "take": {
          "type": "number"
        },
        "ttl": {
          "type": "number"
        },
        "sizingHint": {
          "type": "number"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "side"
      ],
      "additionalProperties": false,
      "description": "Вход в позицию. `side` обязателен — направление в решении, не глобально (FR-006)."
    },
    "ExitDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "exit"
        },
        "target": {
          "type": "string"
        },
        "percent": {
          "type": "number"
        },
        "reason": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "target"
      ],
      "additionalProperties": false,
      "description": "Выход из позиции."
    },
    "AddToPositionDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "add_to_position"
        },
        "mode": {
          "type": "string",
          "enum": [
            "dca",
            "scale_in"
          ]
        },
        "sizingHint": {
          "type": "number"
        }
      },
      "required": [
        "kind",
        "mode"
      ],
      "additionalProperties": false,
      "description": "Доливка/scale-in как intent."
    },
    "UpdateProtectionDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "update_protection"
        },
        "stop": {
          "type": "number"
        },
        "take": {
          "type": "number"
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "description": "Обновление protection-hints (stop/take)."
    },
    "AnnotateDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "annotate"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metrics": {
          "type": "object"
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "description": "Только аннотация/метаданные (без действия)."
    },
    "IdleDecision": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "idle"
        }
      },
      "required": [
        "kind"
      ],
      "additionalProperties": false,
      "description": "Отсутствие действия."
    }
  },
  "title": "StrategyDecision"
}
