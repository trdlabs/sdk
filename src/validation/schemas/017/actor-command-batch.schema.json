{
  "$id": "https://trading-platform/017/actor-command-batch.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ActorCommandBatch",
  "definitions": {
    "ActorCommandBatch": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ActorCommand"
      },
      "description": "Батч команд — то, что актор возвращает из одного `onEvent` и что пересекает JSON-границу изолята. Хост валидирует именно ЕГО (схема `actor-command-batch`): единичная команда — деталь внутри батча, отдельно через границу не ходит."
    },
    "ActorCommand": {
      "anyOf": [
        {
          "$ref": "#/definitions/ActorPlaceCommand"
        },
        {
          "$ref": "#/definitions/ActorCancelCommand"
        },
        {
          "$ref": "#/definitions/ActorTimerSetCommand"
        },
        {
          "$ref": "#/definitions/ActorTimerCancelCommand"
        },
        {
          "$ref": "#/definitions/ActorAnnotateCommand"
        }
      ],
      "description": "Замкнутый union команд актора."
    },
    "ActorPlaceCommand": {
      "anyOf": [
        {
          "$ref": "#/definitions/ActorPlaceMarketCommand"
        },
        {
          "$ref": "#/definitions/ActorPlaceLimitCommand"
        },
        {
          "$ref": "#/definitions/ActorPlaceStopMarketCommand"
        }
      ],
      "description": "Подать заявку. `clientOrderId` — свой, детерминированный (от seed/счётчика); повтор уже живого ID — ошибка хоста, а не молчаливая замена. `qtyUsd` — ПРОСЬБА: RiskEngine клампит или отказывает (`order.denied`)."
    },
    "ActorPlaceMarketCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "place"
        },
        "type": {
          "type": "string",
          "const": "market"
        },
        "clientOrderId": {
          "type": "string"
        },
        "side": {
          "$ref": "#/definitions/OrderSide"
        },
        "qtyUsd": {
          "type": "number",
          "description": "Запрашиваемый нотионал в USD (до клампа риском)."
        },
        "tif": {
          "$ref": "#/definitions/TimeInForce"
        },
        "reduceOnly": {
          "type": "boolean",
          "description": "Заявка только уменьшает экспозицию; проходит и в состоянии REDUCING."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "type",
        "clientOrderId",
        "side",
        "qtyUsd"
      ],
      "additionalProperties": false,
      "description": "Рыночная заявка: исполняется по состоянию среды, цены не несёт."
    },
    "OrderSide": {
      "type": "string",
      "enum": [
        "buy",
        "sell"
      ],
      "description": "Сторона заявки. Отдельно от `'long' | 'short'` решений 017: заявка — buy/sell, не позиция."
    },
    "TimeInForce": {
      "type": "string",
      "enum": [
        "gtc",
        "ioc"
      ],
      "description": "Time-in-force заявки (вокабуляр 083 `ActorCommand.tif`)."
    },
    "ActorPlaceLimitCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "place"
        },
        "type": {
          "type": "string",
          "const": "limit"
        },
        "clientOrderId": {
          "type": "string"
        },
        "side": {
          "$ref": "#/definitions/OrderSide"
        },
        "qtyUsd": {
          "type": "number"
        },
        "price": {
          "type": "number",
          "description": "Лимитная цена."
        },
        "tif": {
          "$ref": "#/definitions/TimeInForce"
        },
        "reduceOnly": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "type",
        "clientOrderId",
        "side",
        "qtyUsd",
        "price"
      ],
      "additionalProperties": false,
      "description": "Лимитная заявка: `price` обязателен, триггера нет."
    },
    "ActorPlaceStopMarketCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "place"
        },
        "type": {
          "type": "string",
          "const": "stop_market"
        },
        "clientOrderId": {
          "type": "string"
        },
        "side": {
          "$ref": "#/definitions/OrderSide"
        },
        "qtyUsd": {
          "type": "number"
        },
        "stopPrice": {
          "type": "number",
          "description": "Триггерная цена."
        },
        "tif": {
          "$ref": "#/definitions/TimeInForce"
        },
        "reduceOnly": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rationale": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "type",
        "clientOrderId",
        "side",
        "qtyUsd",
        "stopPrice"
      ],
      "additionalProperties": false,
      "description": "Стоп-маркет заявка: `stopPrice` обязателен, лимитной цены нет."
    },
    "ActorCancelCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "cancel"
        },
        "clientOrderId": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "clientOrderId"
      ],
      "additionalProperties": false,
      "description": "Отменить свою заявку по её `clientOrderId`. `modify` в v1 нет — place-after-cancel (Q3)."
    },
    "ActorTimerSetCommand": {
      "anyOf": [
        {
          "$ref": "#/definitions/ActorTimerSetAtCommand"
        },
        {
          "$ref": "#/definitions/ActorTimerSetAfterCommand"
        }
      ],
      "description": "Поставить таймер: ЛИБО абсолютный `atTs`, ЛИБО относительный `afterMs` — строго одно из двух. Ни то ни другое (когда будить?) и оба сразу (какое из них истина?) — неоднозначные команды, и обе формы закрыты на уровне схемы, а не соглашением."
    },
    "ActorTimerSetAtCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "timer.set"
        },
        "timerId": {
          "type": "string"
        },
        "atTs": {
          "type": "number",
          "description": "Абсолютный business_ts срабатывания (часы данных, не wall-clock)."
        }
      },
      "required": [
        "kind",
        "timerId",
        "atTs"
      ],
      "additionalProperties": false,
      "description": "Таймер на абсолютный business_ts."
    },
    "ActorTimerSetAfterCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "timer.set"
        },
        "timerId": {
          "type": "string"
        },
        "afterMs": {
          "type": "number",
          "description": "Смещение от `ts` события, породившего команду."
        }
      },
      "required": [
        "kind",
        "timerId",
        "afterMs"
      ],
      "additionalProperties": false,
      "description": "Таймер через `afterMs` от `ts` обрабатываемого события."
    },
    "ActorTimerCancelCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "timer.cancel"
        },
        "timerId": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "timerId"
      ],
      "additionalProperties": false,
      "description": "Снять ранее поставленный таймер."
    },
    "ActorAnnotateCommand": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "const": "annotate"
        },
        "note": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "kind",
        "note"
      ],
      "additionalProperties": false,
      "description": "Только метаданные в трассу — без действия (аналог `AnnotateDecision` в 017)."
    }
  },
  "title": "ActorCommandBatch"
}
