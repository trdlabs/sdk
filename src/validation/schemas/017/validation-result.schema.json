{
  "$id": "https://trading-platform/017/validation-result.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$ref": "#/definitions/ValidationResult",
  "definitions": {
    "ValidationResult": {
      "type": "object",
      "properties": {
        "status": {
          "$ref": "#/definitions/ValidationStatus"
        },
        "normalized": {
          "type": "object"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ValidationIssue"
          }
        }
      },
      "required": [
        "status",
        "issues"
      ],
      "additionalProperties": false,
      "description": "Результат stateless-валидации (FR-021/FR-022/FR-023). `normalized` присутствует при `accepted`/`accepted_with_warnings` (конкретная форма — `NormalizedManifest` из слоя валидатора, `src/research/validation/normalize.ts`). `issues` — полный набор причин (не только первая), стабильно отсортирован по `(path, code)`."
    },
    "ValidationStatus": {
      "type": "string",
      "enum": [
        "accepted",
        "accepted_with_warnings",
        "rejected"
      ],
      "description": "Итоговый статус валидации (правила деривации — data-model §13.1)."
    },
    "ValidationIssue": {
      "type": "object",
      "properties": {
        "severity": {
          "$ref": "#/definitions/Severity"
        },
        "code": {
          "$ref": "#/definitions/ValidationCode"
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "JSON Pointer (RFC 6901) к нарушающему узлу; `\"\"` — корень."
        }
      },
      "required": [
        "severity",
        "code",
        "message",
        "path"
      ],
      "additionalProperties": false,
      "description": "Одна причина: severity + код + объяснение + JSON Pointer (RFC 6901) к узлу."
    },
    "Severity": {
      "type": "string",
      "enum": [
        "error",
        "warning"
      ],
      "description": "Уровень причины: `error` блокирует приём, `warning` — нет."
    },
    "ValidationCode": {
      "type": "string",
      "enum": [
        "schema_invalid",
        "params_schema_invalid",
        "decision_schema_invalid",
        "unsupported_contract_version",
        "unknown_strategy_ref",
        "multi_hook_overlay",
        "lookahead_violation",
        "forbidden_capability",
        "separation_violation",
        "missing_risk_profile",
        "unknown_metric",
        "invalid_module_ref",
        "incomplete_run_request",
        "promotion_requires_review",
        "duplicate_overlay_ref",
        "overlay_composition_invalid",
        "nondeterminism_violation",
        "unsupported_market_data_kind",
        "missing_required_market_data",
        "unsupported_fill_model_kind",
        "unsupported_reality_model_kind",
        "empty_baseline_variant_diff"
      ],
      "description": "Полная таксономия машиночитаемых кодов валидации (data-model §13.2). Error-коды блокируют приём; warning-коды — нет."
    }
  },
  "title": "ValidationResult"
}
