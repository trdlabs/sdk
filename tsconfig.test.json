// Type-check-only проход по тестам. Тесты исполняются через `tsx`, который типы СТИРАЕТ, не
// проверяя, — без этого прохода утверждения о типах в тестах ничем не подкреплены. В частности
// `@ts-expect-error` становится настоящим гейтом: если запрет в типах ослабнет, директива
// окажется лишней и TS2578 уронит сборку.
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["test/**/*.ts", "src/**/*"],
  "exclude": ["dist", "node_modules"]
}
